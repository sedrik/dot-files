	email = sir.sedrik@gmail.com
	name = Sedrik
[core]
    editor = vim
[color]
    ui = true
	diff = auto
	status = auto
	branch = auto
[push]
        default = current
[alias]
    wdiff = diff --color-words
    wshow = show --color-words
    oneline = log master..HEAD --pretty=oneline
    graph = log --graph --oneline
[merge]
    tool = vimdiff
[branch]
	autosetuprebase = always
